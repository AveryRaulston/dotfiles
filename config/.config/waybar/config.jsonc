{
  "layer": "top",
  "height": 20,
  "spacing": 2,
  "margin-top" :5,
  "margin-right" :8,
  "margin-left" :8,

  "modules-left": [
    //"custom/rofi",
    "sway/workspaces",
    "sway/window",
    "hyprland/workspaces",
    "tray",
    "hyprland/window",
  ],

  "modules-center": ["clock"],

  "modules-right": [
    "disk",
    "cpu",
    "memory",
    "temperature",
    "backlight",
    "pulseaudio",
    "battery",
  ],

  "custom/rofi": {
		"format": "<span >¯İ¬</span>",
		"on-click": "rofi -show drun -disable-history -show-icons",
    "on-click-right": "~/.config/custom_scripts/power.sh",
    "escape" : true,
    "tooltip" : false
	},

  // Modules configuration
  "sway/workspaces": {
    "disable-scroll": true,
    "active-only": false,
    "all-outputs": true,
    "warp-on-scroll": false,
    "format": "{icon}",
    "format-icons": {
      "1": "1: ´äá ",
      "2": "2: ¾░ê╣",
      "3": "3",
      "4": "4",
      "5": "5",
      "6": "6",
      "7": "7",
      "8": "8",
      "9": "9: ´üÁ",
      "10": "10",
    }
  },

  "sway/window": {
    "format": "<span color='#202020' bgcolor='#d3869b' > ¾░úå </span> {app_id}",
    "separate-outputs": true,
    "icon":false,
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "active-only": false,
    "all-outputs": true,
    "warp-on-scroll": false,
    "format": "{icon}",
    "format-icons": {
      "1": "<span >¾░ğ¿</span>",
      "2": "<span >¾░ê╣</span>",
      "3": "<span >´äô</span>",
      "4": "<span >´ü╗</span>",
      "5": "<span >´âá</span>",
      "6": "<span >¾░¡ø</span>",
      "7": "<span >¾▒ôÀ</span>",
      "8": "<span >¾░ÜÇ</span>"
    }
  },

  "hyprland/window": {
    "format": "<span color='#202020' bgcolor='#d3869b' > ¾░úå </span> {class}",
    "separate-outputs": true,
    "icon":false,
  },

  "tray": {
    "icon-size": 15,
    "spacing": 8
  },

  "disk": {
    "format": "<span color='#202020' bgcolor='#ea6962' > ´ê│ </span> {free}",
    "interval": 20
  },

  "clock#date": {
    //"intelChicago0,
    "format": "´ü│  {:%e %b %Y}", // Icon: calendar-alt
    "tooltip-format": "{:%e %B %Y}",
    "on-click": "~/work/scripts/popup-calendar.sh --popup"
  },


  "cpu": {
    "format": "<span color='#202020' bgcolor='#e78a4e' > ¯ëĞ </span> {usage}%",
    "tooltip": false,
    "interval": 1
  },

  "temperature": {
    "tooltip":false,
    "thermal-zone": 2,
    "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
    "critical-threshold": 70,
    "format": "<span color='#202020' bgcolor='#d8a657' > ´å╗ </span> {temperatureC}┬░C",
    "format-critical": "<span color='#202020' bgcolor='#cc241d' > ¯©ò </span> {temperatureC}┬░C",
  },

  "backlight": {
    // "device": "acpi_video1",
    "format": "<span color='#202020' bgcolor='#f6c657' > ¾░ŞÅ </span> {percent}%",
    "tooltip": false
  },

  "memory": {
    "format": "´âë {}%", // Icon: memory
    "interval": 5,
    "states": {
      "warning": 70,
      "critical": 90
    }
  },


  "custom/memory": {
    "exec": "~/.config/custom_scripts/memory_usage.sh",
    "interval": 2,
    "return-type": "json",
    "format": "<span color='#202020' bgcolor='#458588' > ¯┐à </span> {}"
  },

  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "<span color='#202020' bgcolor='#83a598' > ´Ç¿ </span> {volume}%",
    "format-muted": "<span color='#202020' bgcolor='#ea6962' > ¯╗¿ </span> {volume}%",
    "format-bluetooth": "<span color='#202020' bgcolor='#83a598' > ¾░é░ </span> {volume}%",
    "format-bluetooth-muted": "<span color='#202020' bgcolor='#ea6962' > ¾░é▓ </span> {volume}%",
    "format-source": "{volume}% ´ä░",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "tooltip": false,
    "max-volume": 130
  },

  "battery#bat2": {
    "bat": "BAT2"
  },

  "battery": {
    "interval": 1,
    "states": {
      "good": 99,
      "warning": 30,
      "critical": 20
    },
    "format-icons": ["¾░éÄ","¾░ü║","¾░ü╗","¾░ü¢","¾░ü¥","¾░ü┐","¾░éÇ","¾░éü","¾░éé","¾░ü╣"],
    "format": "<span color='#202020' bgcolor='#689d6a' > {icon} </span> {capacity}%",
    "format-critical": "<span color='#202020' bgcolor='#cc241d' > {icon} </span> {capacity}%!!",
    "format-warning": "<span color='#202020' bgcolor='#e78a4e' > {icon} </span> {capacity}%",
    "format-full": "<span color='#202020' bgcolor='#689d6a' > {icon} </span> {capacity}%",
    "format-charging": "<span color='#202020' bgcolor='#689d6a' > ¾░éà </span> {capacity}%",
    "format-charging-warning": "<span color='#202020' bgcolor='#e78a4e' > ¾░óØ </span> {capacity}%",
    "format-charging-critical": "<span color='#202020' bgcolor='#cc241d' > ¾░ó£ </span> {capacity}%",
    "format-plugged": "<span color='#202020' bgcolor='#689d6a' > ¾░éà </span> {capacity}%",
    "format-alt": "<span color='#202020' bgcolor='#689d6a' > ¾▒ğÑ </span> {time}",
    "tooltip": false
  },

  "clock": {
    "timezone": "America/Chicago",
    "format": "<span color='#202020' bgcolor='#8ec07c' > ´ü│ </span> {:%a %d %b %H:%M:%S}",
    "tooltip": false,
    "interval":1,
  }
}
